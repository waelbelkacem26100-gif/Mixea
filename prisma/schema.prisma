generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  clerkId         String    @unique
  email           String    @unique
  plan            Plan      @default(FREE)
  auditsThisMonth Int       @default(0)
  resetDate       DateTime  @default(now())
  projects        Project[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  domain    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits    Audit[]
  createdAt DateTime @default(now())

  @@unique([userId, domain])
}

model Audit {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url             String
  competitorUrl   String?
  scoreGlobal     Int
  scoreSeo        Int
  scorePerf       Int
  scoreUx         Int
  scoreContent    Int
  scoreSecurity   Int
  scoreSocial     Int
  scoreCompetitor Int?
  duration        Int
  results         AuditResult[]
  sharedSlug      String?       @unique
  pagespeedCache  Json?
  createdAt       DateTime      @default(now())

  @@index([projectId])
}

model AuditResult {
  id              String   @id @default(cuid())
  auditId         String
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  module          String
  type            String
  severity        String
  label           String
  value           String
  impact          String
  explanation     String?
  action          String?
  fix             String?
  competitorValue String?
  createdAt       DateTime @default(now())
}

enum Plan {
  FREE
  STARTER
  PRO
}
